<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Ecommerce Automation Suite" parallel="false">
    <listeners>
        <listener class-name="com.ecommerce.automation.listeners.ExtentTestListener"/>
    </listeners>

    <test name="Functional Tests">
        <classes>
            <class name="com.ecommerce.automation.tests.LoginTests"/>
            <class name="com.ecommerce.automation.tests.CartCheckoutTests"/>
            <class name="com.ecommerce.automation.tests.InvalidInputTests"/>
        </classes>
    </test>
</suite>
